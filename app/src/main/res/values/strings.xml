    <string name="layout_mode_circle_description">Places apps on circular rings around the center, keeping equal distance between items for radial navigation.</string>
    <string name="layout_mode_oval_description">Places apps on elliptical rings, giving more horizontal spread while preserving comfortable gaps.</string>
    <string name="layout_mode_smart_auto_description">Uses a smarter semantic + package analysis to group apps more accurately across languages, then places each group in a labeled frame.</string>
    <string name="layout_mode_icon_color_description">Analyzes each icon and groups apps by dominant icon color. Every color group gets its own labeled frame.</string>


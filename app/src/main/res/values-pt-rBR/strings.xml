    <string name="layout_mode_smart_auto_description">Usa análise semântica e de pacote aprimorada para agrupar apps com mais precisão entre idiomas e posiciona cada grupo em um frame com rótulo.</string>
    <string name="layout_mode_icon_color_description">Analisa cada ícone e agrupa apps pela cor dominante do ícone. Cada grupo de cor recebe seu próprio frame com rótulo.</string>

